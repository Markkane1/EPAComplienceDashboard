{
  "name": "epa-compliance-dashboard",
  "version": "0.0.0",
  "private": true,
  "workspaces": ["apps/web", "apps/api", "packages/*"],
  "scripts": {
    "dev": "concurrently -n WEB,API \"npm run dev:web\" \"npm run dev:api\"",
    "dev:full": "concurrently -n WEB,API \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:api": "npm --prefix apps/api run dev",
    "build": "npm --prefix apps/web run build",
    "build:production": "npm --prefix apps/web run build -- --mode production",
    "build:staging": "npm --prefix apps/web run build -- --mode staging",
    "start:api": "npm --prefix apps/api run start",
    "start:staging:api": "npm --prefix apps/api run start",
    "preview:staging:web": "npm --prefix apps/web run preview -- --host 0.0.0.0 --port 8080",
    "setup:staging": "node ./scripts/setup-staging-env.mjs",
    "setup:production": "node ./scripts/setup-production-env.mjs",
    "deploy:oracle": "bash ./scripts/oracle/deploy.sh",
    "setup:oracle:vm": "bash ./scripts/oracle/bootstrap-ubuntu.sh",
    "setup:oracle:nginx": "bash ./scripts/oracle/setup-nginx.sh",
    "lint:web": "npm --prefix apps/web run lint",
    "lint:api": "npm --prefix apps/api run lint"
  },
  "dependencies": {
    "concurrently": "^9.2.0",
    "tslib": "^2.8.0",
    "vite": "^5.4.19"
  }
}
