{
  "name": "epa-compliance-dashboard",
  "version": "0.0.0",
  "private": true,
  "workspaces": ["apps/web", "apps/api", "packages/*"],
  "scripts": {
    "build": "npm --prefix apps/web run build -- --mode production",
    "build:production": "npm --prefix apps/web run build -- --mode production",
    "start:api": "npm --prefix apps/api run start",
    "setup:production": "node ./scripts/setup-production-env.mjs",
    "deploy:oracle": "bash ./scripts/oracle/deploy.sh",
    "setup:oracle:vm": "bash ./scripts/oracle/bootstrap-ubuntu.sh",
    "setup:oracle:nginx": "bash ./scripts/oracle/setup-nginx.sh",
    "lint:web": "npm --prefix apps/web run lint",
    "lint:api": "npm --prefix apps/api run lint"
  },
  "dependencies": {
    "concurrently": "^9.2.0",
    "tslib": "^2.8.0",
    "vite": "^5.4.19"
  }
}
