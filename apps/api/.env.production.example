# EPA Compliance Dashboard - API Production Configuration
# Copy to apps/api/.env on the VM.

NODE_ENV=production
PORT=8080
# Set true only after HTTPS is configured (domain + SSL)
ENFORCE_HTTPS=false

# Database
MONGO_URI=mongodb+srv

# Security
JWT_SECRET=ChangeThisToSomethingSecure1234567890abcdef
ADMIN_PASSWORD=AdminPassword123!

# Bootstrap admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_NAME=System Administrator
ADMIN_CNIC=0101001001011

# Frontend host(s) allowed to call API
# If no domain yet, use your VM public IP, e.g. http://123.45.67.89
CORS_ORIGIN=http://129.159.26.1

# Public URLs used in links and file URLs
# If no domain yet, keep these as HTTP IP URLs.
PUBLIC_BASE_URL=http://129.159.26.1 
APP_BASE_URL=http://129.159.26.1

# Upload storage
UPLOAD_DIR=./uploads
SECURE_UPLOADS_DIR=../secure-uploads

# Email provider (Resend)
RESEND_API_KEY=re_YXs1_EUSIkoLwd
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=EPA Compliance Dashboard
