# EPA Compliance Dashboard - API Staging Configuration
# Copy to apps/api/.env on your staging server and fill all placeholders.

# Keep production-grade behavior in staging
NODE_ENV=production
PORT=4000

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/punjab_compliance_staging?retryWrites=true&w=majority

# Security
JWT_SECRET=replace-with-32-plus-char-random-secret
ADMIN_PASSWORD=replace-with-strong-admin-password

# Admin bootstrap
ADMIN_EMAIL=admin-staging@yourdomain.com
ADMIN_NAME=Staging Administrator
ADMIN_CNIC=your-admin-cnic

# Restrict CORS to staging frontend domains only
CORS_ORIGIN=https://staging.yourdomain.com

# Public URLs
PUBLIC_BASE_URL=https://staging-api.yourdomain.com
APP_BASE_URL=https://staging.yourdomain.com

# File Upload Configuration
UPLOAD_DIR=./uploads
SECURE_UPLOADS_DIR=../secure-uploads

# Resend Configuration
# For production-like staging, use a verified domain sender.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=notifications@yourdomain.com
EMAIL_FROM_NAME=EPA Compliance Dashboard (Staging)
